# ============================================================================
# Front CMS (backoffice) — conexión DIRECTA a cms-service.
# El Front CMS NO pasa por el web-bff-service (ese es la puerta del front
# público). Regla: Front CMS ─► cms-service ─► DB CMS.
# ============================================================================

# URL de cms-service (prefijo api/cms). Ejemplos:
#   directo (dev):  NEXT_PUBLIC_CMS_SERVICE_URL=http://localhost:3040/api/cms
#   vía gateway:    NEXT_PUBLIC_CMS_SERVICE_URL=https://api.mimbral.cl/api/cms
# Vacío o ausente = el backoffice funciona con los datos de ejemplo (mocks).
NEXT_PUBLIC_CMS_SERVICE_URL=

# Timeout por request (ms). Opcional; por defecto 8000.
# NEXT_PUBLIC_CMS_TIMEOUT_MS=8000

# Contexto de admin (modelo Janis/api-gateway). En dev directo, cms-service
# asume permisos '*' si no llegan; en prod los inyecta el gateway.
# NEXT_PUBLIC_CMS_ADMIN_USER_ID=cms-web
# NEXT_PUBLIC_CMS_CLIENT=cms-web
# NEXT_PUBLIC_CMS_ADMIN_PERMISSIONS=*
